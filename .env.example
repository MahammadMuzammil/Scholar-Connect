# Copy to `.env` and fill in real values there. This file is a TEMPLATE and
# should NEVER contain real secrets — it is committed to git.
# Inline comments on the same line as a value are NOT supported — put comments
# on their own line.

# --- Video (Daily.co) — https://dashboard.daily.co/developers
DAILY_API_KEY=
# subdomain only, e.g. "yourteam" — NOT "yourteam.daily.co"
DAILY_DOMAIN=

# --- Email (Resend) — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=ScholarConnect <onboarding@resend.dev>

# --- WhatsApp (Twilio) — https://console.twilio.com
# For testing: enable WhatsApp Sandbox in Twilio console, note the "From" number,
# then each recipient messages "join <your-code>" to that number once to opt in.
# For production: request a dedicated WhatsApp sender and get templates approved.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio sandbox number — keep the leading +, no "whatsapp:" prefix
TWILIO_WHATSAPP_FROM=+14155238886
# Admin's WhatsApp number — receives a "new payment to verify" message with the
# UTR each time a booking is created. Same opt-in rule as scholars: the admin's
# phone must text "join gradually-prevent" to +14155238886 once.
ADMIN_WHATSAPP=

# --- Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
# VITE_* vars are baked into the frontend bundle at build time.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS for admin operations (scholar approval).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Scholar applications
# Long random string used to sign approval URLs (HMAC).
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
APPROVAL_SECRET=
# Email address that receives "new scholar application" notifications.
ADMIN_EMAIL=mhammadmuzammil635@gmail.com

# --- Server
PORT=3001

# Public URL used inside notification messages. On Vercel, set this to your
# production domain (e.g. https://scholar-connect.vercel.app). Leaving blank
# on Vercel falls back to VERCEL_URL automatically.
PUBLIC_WEB_URL=http://localhost:5173
